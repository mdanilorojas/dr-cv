{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/artifact/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono|Source Serif 4))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono, Source Serif 4."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|children|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:info|success|warning|danger)$/]",
        "message": "<Alert> variant must be one of 'info' | 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Artifact'] > JSXAttribute > JSXIdentifier[name!=/^(?:file|meta|status|className|children|key|ref|className|style|children)$/]",
        "message": "<Artifact> doesn't accept that prop. Declared props: file, meta, status, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|initials|size|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, initials, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:base|lg)$/]",
        "message": "<Avatar> size must be one of 'base' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|mono|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, dot, mono, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|primary|accent|success|warning|danger|info)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'primary' | 'accent' | 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconOnly|block|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconOnly, block, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|base|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'base' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:pad|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: pad, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiffRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|text|key|ref|className|style|children)$/]",
        "message": "<DiffRow> doesn't accept that prop. Declared props: type, text."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiffRow'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:add|del|ctx)$/]",
        "message": "<DiffRow> type must be one of 'add' | 'del' | 'ctx'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|help|search|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, help, search."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mastery'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|children|key|ref|className|style|children)$/]",
        "message": "<Mastery> doesn't accept that prop. Declared props: level, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mastery'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:mastered|proficient|developing|novice|gap)$/]",
        "message": "<Mastery> level must be one of 'mastered' | 'proficient' | 'developing' | 'novice' | 'gap'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlanStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|done|key|ref|className|style|children)$/]",
        "message": "<PlanStep> doesn't accept that prop. Declared props: label, done."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|lg|tone|className|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, lg, tone, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|cool|pos)$/]",
        "message": "<ProgressBar> tone must be one of 'accent' | 'cool' | 'pos'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Segmented'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|value|onChange|className|key|ref|className|style|children)$/]",
        "message": "<Segmented> doesn't accept that prop. Declared props: items, value, onChange, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|help|children|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, help, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|height|radius|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: width, height, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<SkillChip> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stream'] > JSXAttribute > JSXIdentifier[name!=/^(?:caret|children|key|ref|className|style|children)$/]",
        "message": "<Stream> doesn't accept that prop. Declared props: caret, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: children."
      }
    ]
  },
